---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, titleZh, description, descriptionZh, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
	</head>

	<body>
		<Header />
		<main class="post-shell">
			<article>
				<header class="post-header">
					<h4>
						<span class="lang-en">{title}</span>
						<span class="lang-zh">{titleZh || title}</span>
					</h4>
					<p class="dek">
						<span class="lang-en">{description}</span>
						<span class="lang-zh">{descriptionZh || description}</span>
					</p>
				</header>

				{heroImage && <Image class="hero-image" width={1200} height={630} src={heroImage} alt="" />}

				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.post-shell {
		width: min(100% - 32px, 760px);
		margin: 0 auto;
		padding: 74px 0 72px;
	}

	.post-header {
		margin-bottom: 42px;
	}

	.back-link {
		display: inline-block;
		margin-bottom: 28px;
		color: rgb(var(--muted));
		font-size: 0.9rem;
		text-decoration: none;
	}

	.back-link::before {
		content: "< ";
	}

	.back-link:hover {
		color: rgb(var(--accent));
	}

	.date {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-bottom: 18px;
		color: rgb(var(--muted));
		font-size: 0.88rem;
	}

	h1 {
		margin: 0;
		font-size: clamp(2.4rem, 7vw, 5rem);
		font-weight: 700;
		line-height: 1;
	}

	.dek {
		max-width: 620px;
		margin: 22px 0 0;
		color: rgb(var(--muted));
		font-size: 1rem;
		line-height: 1.75;
	}

	.hero-image {
		display: block;
		width: 100%;
		margin: 0 0 48px;
		border-radius: 4px;
	}

	.prose {
		color: rgb(var(--gray-dark));
		font-size: 1rem;
		line-height: 1.85;
	}

	@media (max-width: 620px) {
		.post-shell {
			padding: 52px 0;
		}

		.hero-image {
			margin-bottom: 36px;
		}
	}
</style>
