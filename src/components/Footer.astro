---

<footer class="site-footer">
	<div class="footer-links">
		<a href="/license">
			<span class="lang-en">MIT License</span>
			<span class="lang-zh">MIT 许可</span>
		</a>
	</div>
	<a class="telegram-link" href="https://t.me/yourusername" target="_blank" rel="noopener noreferrer" aria-label="Telegram">
		<svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
			<path d="M1.5 10.5L21 2l-8.5 20L9 13.5l-7.5-3z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
			<path d="M9 13.5L21 2" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
		</svg>
	</a>
</footer>

<style>
	.site-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: min(100% - 32px, 760px);
		margin: 0 auto;
		padding: 48px 0 72px;
		color: rgb(var(--muted));
		font-size: 0.85rem;
	}

	.footer-links {
		display: flex;
		align-items: center;
		gap: 0.35rem;
	}

	.footer-links a {
		color: rgb(var(--muted));
		text-decoration: none;
		padding: 2px 4px;
		border-radius: 4px;
		transition: color 160ms ease;
	}

	.footer-links a:hover {
		color: rgb(var(--black));
	}

	.footer-links a + a::before {
		content: "/";
		margin-right: 0.35rem;
		color: rgb(var(--line-strong));
		pointer-events: none;
	}

	.telegram-link {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		border-radius: 6px;
		color: rgb(var(--muted));
		transition: color 160ms ease, background 160ms ease;
	}

	.telegram-link:hover {
		color: rgb(var(--accent));
		background: rgba(var(--accent), 0.08);
	}

	@media (max-width: 620px) {
		.site-footer {
			flex-direction: column;
			gap: 12px;
			padding: 36px 0 56px;
		}
	}
</style>
