---
import img1 from '../../assets/midjourney1.png';
import img2 from '../../assets/midjourney2.png';
import img3 from '../../assets/midjourney3.png';
import img4 from '../../assets/midjourney4.png';
import img5 from '../../assets/midjourney5.png';
import img6 from '../../assets/midjourney6.png';
import img7 from '../../assets/midjourney7.png';
import img8 from '../../assets/midjourney8.png';
import img9 from '../../assets/midjourney9.png';
import img10 from '../../assets/midjourney10.png';
import defaultImg from '../../assets/midjourney11.png';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const allImages = [img1, img2, img3, img4, img5, img6, img7, img8, img9, img10];

const projects = [
	{
		id: 'quokka',
		image: allImages[0],
		title: 'Quokka Blog',
		titleZh: 'Quokka 博客',
		description: 'A minimal, bilingual Astro blog theme with content collections and RSS support.',
		descriptionZh: '一个极简的双语 Astro 博客主题，支持内容集合和 RSS。',
		url: 'https://github.com/ardour100/Astro-Quokka',
	},
	{
		id: 'toolkit',
		image: allImages[1],
		title: 'Dev Toolkit',
		titleZh: '开发工具包',
		description: 'A collection of reusable utilities and components for modern web development.',
		descriptionZh: '一系列用于现代 Web 开发的可复用工具和组件。',
		url: '#',
	},
	{
		id: 'dashboard',
		image: allImages[2],
		title: 'Analytics Dashboard',
		titleZh: '分析仪表盘',
		description: 'Real-time metrics and insights dashboard built with TypeScript and D3.js.',
		descriptionZh: '使用 TypeScript 和 D3.js 构建的实时指标和洞察仪表盘。',
		url: '#',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} / Projects`} description="Projects and experiments." />
	</head>
	<body>
		<Header />
		<main class="projects-index">
			<section class="project-grid" aria-label="Projects">
				{
					projects.map((project) => (
						<a class="project-card" href={project.url}>
							<div class="card-image">
								<img src={project.image.src} alt="" loading="lazy" class="project-img" data-id={project.id} onerror={'this.onerror=null;this.src=\'' + defaultImg.src + '\''} />
							</div>
							<div class="card-body">
								<h3 class="card-title">
									<span class="lang-en">{project.title}</span>
									<span class="lang-zh">{project.titleZh}</span>
								</h3>
								<p class="card-desc">
									<span class="lang-en">{project.description}</span>
									<span class="lang-zh">{project.descriptionZh}</span>
								</p>
							</div>
						</a>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.projects-index {
		width: min(100% - 32px, 920px);
		margin: 0 auto;
		padding: 38px 0 72px;
	}

	.project-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
	}

	.project-card {
		display: flex;
		flex-direction: column;
		border-radius: 12px;
		overflow: hidden;
		background: #fff;
		text-decoration: none;
		box-shadow:
			0 1px 0 rgba(255, 255, 255, 0.9) inset,
			0 10px 24px rgba(83, 125, 150, 0.06),
			0 0 0 1px rgba(68, 161, 148, 0.04) inset;
		transition:
			transform 200ms ease,
			box-shadow 200ms ease;
	}

	.project-card:hover,
	.project-card:focus-visible {
		transform: translateY(-4px);
		box-shadow:
			0 1px 0 rgba(255, 255, 255, 0.95) inset,
			0 18px 36px rgba(83, 125, 150, 0.1),
			0 0 0 1px rgba(68, 161, 148, 0.06) inset;
		outline: none;
	}

	.project-card:active {
		transform: translateY(-1px);
	}

	.card-image {
		flex: 1;
		min-height: 0;
		width: 100%;
		overflow: hidden;
		background: rgb(var(--paper));
	}

	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		transition: transform 300ms ease;
	}

	.project-card:hover .card-image img,
	.project-card:focus-visible .card-image img {
		transform: scale(1.04);
	}

	.card-body {
		flex: 1;
		padding: 18px 20px 22px;
	}

	.card-title {
		margin: 0 0 6px;
		font-size: 1.1rem;
		font-weight: 650;
		color: rgb(var(--black));
		line-height: 1.35;
	}

	.project-card:hover .card-title,
	.project-card:focus-visible .card-title {
		color: rgb(var(--accent));
	}

	.card-desc {
		margin: 0;
		font-size: 0.88rem;
		line-height: 1.6;
		color: rgb(var(--muted));
	}

	@media (max-width: 820px) {
		.project-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 18px;
		}
	}

	@media (max-width: 520px) {
		.projects-index {
			padding: 28px 0 52px;
		}

		.project-grid {
			grid-template-columns: 1fr;
			gap: 16px;
		}

		.card-body {
			padding: 14px 16px 18px;
		}
	}
</style>
